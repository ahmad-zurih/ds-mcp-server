# --- ds-mcp-server configuration ---
# Copy this file to `.env` in the folder where you'll run ds-mcp-webui / ds-mcp-client,
# uncomment the block for your provider, and fill in your credentials.
#
# You can also set these as regular environment variables — the .env file is
# just a convenience. Precedence: real environment > .env file.

# ==========================================
# OpenAI
# ==========================================
PROVIDER=openai
API_KEY=sk-YOUR_KEY_HERE
MODEL=gpt-4o

# ==========================================
# Anthropic Claude (uncomment to use)
# ==========================================
# PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# MODEL=claude-opus-4-5

# ==========================================
# Google Gemini via OpenAI-compatible endpoint (uncomment to use)
# ==========================================
# PROVIDER=gemini
# API_KEY=AIza-YOUR_KEY_HERE
# MODEL=gemini-2.0-flash

# ==========================================
# Ollama (local, no API key needed) (uncomment to use)
# ==========================================
# PROVIDER=ollama
# API_BASE_URL=http://localhost:11434/v1
# MODEL=llama3

# ==========================================
# LM Studio / GPUStack / any OpenAI-compatible server (uncomment to use)
# ==========================================
# PROVIDER=openai-compat
# API_BASE_URL=https://your-endpoint.example/v1
# API_KEY=your-key-here
# MODEL=your-model-name

# ==========================================
# Multi-agent mode (optional) — `ds-mcp-client --multi-agent`, or the
# "Multi-agent" toggle in the ds-mcp-webui sidebar.
# ==========================================
# A supervisor LLM (no tools) delegates category-scoped subtasks to worker LLMs.
# Leave these unset to reuse MODEL for both roles. Tip: a strong planner + a
# cheaper worker model keeps quality high while cutting cost.
# PLANNER_MODEL=gpt-4o
# WORKER_MODEL=gpt-4o-mini
# MAX_ROUNDS=3            # supervisor re-planning rounds
# MAX_WORKER_RETRIES=2   # times a worker retries a failed task
# MAX_WORKER_STEPS=6     # tool-call iterations inside one worker task
# DS_MCP_MULTI_AGENT=1   # start the web UI with multi-agent already on
