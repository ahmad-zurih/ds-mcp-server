# Copy to .env and fill in your values.

# Provider: openai | anthropic | gemini | ollama | openai-compat
PROVIDER=openai

# Model to use (auto-set per provider if left blank)
# MODEL=gpt-4o

# API key
API_KEY=sk-YOUR_KEY_HERE

# Base URL (only needed for openai-compat, ollama, or self-hosted)
# API_BASE_URL=https://api.openai.com/v1
# API_BASE_URL=http://localhost:11434/v1          # Ollama
# API_BASE_URL=https://your-gpustack-host/v1      # GPUStack
# API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  # Gemini via OpenAI compat
